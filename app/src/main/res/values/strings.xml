    <string name="app_subtitle">5G/LTE coverage scanner</string>
    <string name="consent_intro">5G-Scanner helps build a coverage map from real phones carried by volunteers. Before it collects anything, it needs your consent.</string>
    <string name="consent_data_scope_title">Data collected</string>
    <string name="consent_data_scope">When scanning is enabled, the app collects location, time, device and OS details, carrier/connectivity state, and 5G/LTE signal measurements where Android exposes them.</string>
    <string name="consent_storage_title">Storage and reporting</string>
    <string name="consent_local_only">Coverage samples are stored on this device first and reported according to your reporting setting.</string>
    <string name="consent_control_title">Your control</string>
    <string name="consent_reversible">After consent, scanning can run quietly in the background. You can stop scanning when you want to pause participation, save battery, or go off duty.</string>
