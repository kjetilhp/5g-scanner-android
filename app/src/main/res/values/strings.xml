    <string name="consent_local_only">This prototype stores daily JSONL logs locally under Documents/Ask. Upload and sharing are not enabled.</string>
    <string name="consent_control_title">Your control</string>
    <string name="consent_reversible">After consent, scanning starts automatically unless stopped. You can stop scanning later or uninstall the app to stop participating.</string>
