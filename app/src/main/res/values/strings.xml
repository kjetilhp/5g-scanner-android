    <string name="app_subtitle">5G/LTE coverage scanner</string>
    <string name="consent_intro">5G-Scanner helps build an evolving coverage map for 5G/LTE connectivity. Before it collects anything, it needs your consent.</string>
    <string name="consent_data_scope_title">Data collected</string>
    <string name="consent_data_scope">When scanning is enabled, the app collects location, time and 5G/LTE signal measurements. Your device hardware and OS details are also collected. No further information about the user is collected.</string>
    <string name="consent_storage_title">Storage and reporting</string>
    <string name="consent_local_only">Coverage samples are stored on this device and reported to our servers according to your reporting setting.</string>
    <string name="consent_control_title">Your control</string>
    <string name="consent_reversible">After consent, scanning can run quietly in the background. You can stop scanning whenever you want, for instance to save battery.</string>
