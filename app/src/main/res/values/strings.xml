    <string name="consent_intro">Before scanning, Ask needs your consent. Participation is voluntary.</string>
    <string name="consent_data_scope">When scanning is enabled, the app will collect location, timestamps, connectivity state, and cellular radio measurements where Android exposes them.</string>
    <string name="consent_local_only">This prototype stores data locally only. Upload and sharing are not enabled.</string>
