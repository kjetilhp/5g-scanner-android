    <string name="setting_mock_telemetry_summary">Use synthesized data instead of actual radio and GNSS readings.</string>
    <string name="setting_mock_telemetry_emulator_summary">Mock telemetry is always used on emulators.</string>
    <string name="about_intro_title">About</string>
    <string name="about_intro_body">5G-Scanner builds a real coverage data set from voluntary signal measurements collected while people carry their phones.</string>
    <string name="about_data_title">Data collected</string>
    <string name="about_data_body">Location, time, device and OS details, carrier/connectivity state, and 5G/LTE signal measurements where Android exposes them.</string>
    <string name="about_privacy_title">Privacy</string>
    <string name="about_privacy_body">Coverage data is used for mapping signal quality over time. It is not intended to identify you or be traced back to you.</string>
    <string name="about_storage_title">Storage and reporting</string>
    <string name="about_storage_body">Samples are stored on this device first and reported according to your reporting setting.</string>
    <string name="about_participation_title">Participation</string>
    <string name="about_participation_body">You can stop scanning to pause participation, delete local coverage data, or uninstall the app to stop participating.</string>
